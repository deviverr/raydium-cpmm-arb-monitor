{
  "name": "raydium-cpmm-arb-monitor",
  "version": "0.1.0",
  "description": "Real-time arbitrage monitoring tool for Raydium CPMM pools",
  "main": "dist/index.js",
  "bin": {
    "raydium-arb-monitor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --no-warnings dist/index.js",
    "demo": "node --no-warnings dist/index.js --demo",
    "dev": "ts-node src/index.ts",
    "dev:demo": "ts-node src/index.ts --demo",
    "clean": "rimraf dist",
    "test": "jest --testPathPattern=tests/.*\\.test\\.ts"
  },
  "keywords": [
    "solana",
    "raydium",
    "cpmm",
    "arbitrage",
    "monitoring",
    "defi"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@raydium-io/raydium-sdk-v2": "0.2.41-alpha",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.3",
    "bn.js": "^5.2.1",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "rimraf": "^5.0.9",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

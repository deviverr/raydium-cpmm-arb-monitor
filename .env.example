# Solana RPC endpoint (Helius recommended for getProgramAccounts performance)
# Get a free key at https://helius.dev
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# How often to refresh pool prices (milliseconds)
POLLING_INTERVAL_MS=5000

# Minimum net profit (in input token units) to surface as actionable opportunity
# Opportunities below this threshold are still computed but flagged as "below threshold"
MIN_PROFIT_THRESHOLD=0.0001

# Notional trade size used to simulate arbitrage (in input token units, mintA)
# Net profit is calculated for swapping this amount through the buy pool then sell pool
TRADE_AMOUNT=1

# Estimated transaction cost for a 2-leg arbitrage (in lamports)
# Covers base fee + priority fee for both swap transactions
TX_COST_LAMPORTS=10000

# Logging
LOG_LEVEL=info
LOG_FILE=arb-monitor.log
